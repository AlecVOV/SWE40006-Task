<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

	<Product Id="*" Name="My Example Installer" Language="1033" Version="1.0.0.0" Manufacturer="HP Inc." UpgradeCode="2186e238-e005-4aa4-b5f8-186182232627">
		<Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

		<MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

		<MediaTemplate EmbedCab="yes" />

		<Feature Id="ProductFeature" Title="Setup_Project" Level="1">
			<ComponentGroupRef Id="ProductComponents" />
		</Feature>
	</Product>

	<Fragment>
		<Directory Id="TARGETDIR" Name="SourceDir">
			<Directory Id="ProgramFilesFolder">
				<Directory Id="INSTALLFOLDER" Name="My Example Installer" />
			</Directory>
		</Directory>
	</Fragment>

	<Fragment>
		<ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

			<Component Id="MainExecutable" Guid="73EB23F1-8C5D-47FE-9893-BAB4FB1D4A70">
				<File Id="MyApplicationFile"
					  Name="Task_1.1P.exe"
					  Source="$(var.Task_1.1P.TargetDir)Task_1.1P.exe" />
			</Component>

		</ComponentGroup>
	</Fragment>
</Wix>